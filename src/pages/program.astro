---
// src/components/widgets/Program.astro
---

<section id="program" class="mx-auto max-w-4xl px-6 py-16 sm:py-20 text-slate-800 dark:text-slate-200">
  <div class="text-center mb-10">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
      Program
    </h2>
    <div class="w-16 h-1 bg-blue-600 mx-auto rounded"></div>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 mx-auto max-w-3xl">
    <a
      href="https://easychair.org/smart-program/SBMF2026/"
      target="_blank"
      rel="noopener noreferrer"
      class="group block p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 hover:border-blue-600 dark:hover:border-blue-400 transition-colors shadow-sm hover:shadow-md"
    >
      <div class="flex flex-col h-full justify-between">
        <div>
          <h3 class="text-xl font-semibold mb-2 text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
            Detailed Program
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Access the full schedule, presentation times, and details on EasyChair.
          </p>
        </div>
        <div class="mt-6 flex items-center text-blue-600 dark:text-blue-400 text-sm font-semibold uppercase tracking-wider">
          View Program <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </div>
    </a>

    <a
      href="https://link.springer.com/book/10.1007/978-3-032-12086-1"
      target="_blank"
      rel="noopener noreferrer"
      class="group block p-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 hover:border-blue-600 dark:hover:border-blue-400 transition-colors shadow-sm hover:shadow-md"
    >
      <div class="flex flex-col h-full justify-between">
        <div>
          <h3 class="text-xl font-semibold mb-2 text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
            Online Proceedings
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Read the published papers and symposium proceedings on Springer Link.
          </p>
        </div>
        <div class="mt-6 flex items-center text-blue-600 dark:text-blue-400 text-sm font-semibold uppercase tracking-wider">
          View Proceedings <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </div>
    </a>
  </div>
</section>