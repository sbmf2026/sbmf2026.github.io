---
// src/components/widgets/ImportantDates.astro

// Centralizando as datas em um array para facilitar futuras atualizações
const dates = [
  {
    event: 'Paper registration deadline',
    originalDate: 'July 11th, 2026',
    currentDate: 'July 31st, 2026',
    isExtended: false,
  },
  {
    event: 'Paper submission deadline',
    originalDate: null,
    currentDate: 'August 7th, 2026',
    isExtended: false,
  },
  {
    event: 'Acceptance notification',
    originalDate: null,
    currentDate: 'September 25th, 2026',
    isExtended: false,
  },
  {
    event: 'Camera-ready deadline',
    originalDate: null,
    currentDate: 'October 9th, 2026',
    isExtended: false,
  },
  {
    event: 'SBMF 2026',
    originalDate: null,
    currentDate: 'December 3rd to 5th, 2026',
    isExtended: false,
  },
];
---

<section id="important-dates" class="mx-auto max-w-4xl px-4 sm:px-6 py-16 sm:py-20">
  
  <div class="text-center mb-10 sm:mb-12">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4 text-slate-900 dark:text-white">
      Important Dates
    </h2>
    <div class="w-16 h-1 bg-blue-600 mx-auto rounded mb-6"></div>
    <p class="text-lg text-slate-600 dark:text-slate-400">
      Mark your calendars. All deadlines are <span class="font-semibold text-slate-800 dark:text-slate-200">Anywhere on Earth (AoE)</span>.
    </p>
  </div>

  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm overflow-hidden">
    <ul class="divide-y divide-slate-100 dark:divide-slate-800">
      {dates.map((item) => (
        <li class="flex flex-col sm:flex-row sm:items-center justify-between p-5 sm:p-6 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
          
          <div class="mb-3 sm:mb-0">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
              {item.event}
            </h3>
          </div>

          <div class="flex flex-col sm:items-end">
            {item.isExtended ? (
              <>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm text-slate-400 dark:text-slate-500 line-through">
                    {item.originalDate}
                  </span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 uppercase tracking-wider">
                    Extended
                  </span>
                </div>
                <span class="text-base font-bold text-red-600 dark:text-red-400">
                  {item.currentDate}
                </span>
              </>
            ) : (
              <span class="text-base font-bold text-blue-600 dark:text-blue-400">
                {item.currentDate}
              </span>
            )}
          </div>

        </li>
      ))}
    </ul>
  </div>

</section>