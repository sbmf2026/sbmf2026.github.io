<section id="committees" class="mx-auto max-w-7xl px-4 sm:px-6 py-16 sm:py-20 text-slate-800 dark:text-slate-200">
  
  <div class="text-center mb-16">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4 text-slate-900 dark:text-white">
      Committees
    </h2>
    <div class="w-16 h-1 bg-blue-600 mx-auto rounded"></div>
  </div>

  <div class="mb-24">
    <h3 class="text-3xl font-bold mb-12 text-center text-slate-900 dark:text-white border-b border-slate-200 dark:border-slate-800 pb-4">
      Organizing Committee
    </h3>
     <!--
    <div class="space-y-16">
      {organizingGroups.map((group) => (
        <div>
          <h4 class="text-lg font-bold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-8 text-center">
            {group.role}
          </h4>
          
          <div class="flex flex-wrap justify-center gap-6">
            {group.members.map((member) => (
              <div class="w-full sm:w-[calc(50%-1.5rem)] md:w-[calc(33.333%-1.5rem)] lg:w-[calc(25%-1.5rem)] flex flex-col items-center text-center p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm transition hover:shadow-md hover:border-blue-300 dark:hover:border-blue-700">
                
                <img 
                  src={member.image} 
                  alt={member.name} 
                  loading="lazy"
                  class="w-28 h-28 rounded-full object-cover object-top shadow-sm mb-4 ring-4 ring-slate-50 dark:ring-slate-800/50"
                />
                
                <p class="font-bold text-lg text-slate-900 dark:text-white leading-tight mb-2">
                  {member.name}
                </p>
                
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                  {member.institution}
                </p>
                
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
     -->

    <div class="mt-8 text-center">
      <p class="text-sm text-slate-500 dark:text-slate-400">Contact the organizing committee at</p>

      <a
        href="mailto:sbmf2026@easychair.org"
        class="inline-block mt-2 px-4 py-2 rounded-lg bg-white/60 dark:bg-slate-800/60 backdrop-blur-md border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-800 dark:text-slate-200 hover:bg-white/80 dark:hover:bg-slate-700/60 transition"
      >
        sbmf2026@easychair.org
      </a>
    </div>
  </div>

  <div>
    <h3 class="text-3xl font-bold mb-10 text-center text-slate-900 dark:text-white border-b border-slate-200 dark:border-slate-800 pb-4">
      Program Committee
    </h3>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 sm:p-10 shadow-sm">
      
      <ul class="columns-1 sm:columns-2 lg:columns-3 gap-x-8 gap-y-4">
         <p class="mb-0 text-slate-700 dark:text-slate-300">
          To be announced
         </p>
       <!-- 
       {programCommittee.map((member) => (
          <li class="mb-5 break-inside-avoid flex items-start gap-3">
            <span class="text-blue-500 mt-0.5 shrink-0">❖</span>
            <div>
              <p class="font-semibold text-slate-900 dark:text-slate-200 text-sm">
                {member.name}
              </p>
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                {member.inst}
              </p>
            </div>
          </li>
        ))}
        -->
      </ul>
      
    </div>
  </div>

      

</section>